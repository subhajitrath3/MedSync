# Root .gitignore for MedSync Project

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
*.test.js.snap

# Production builds
dist/
dist-ssr/
build/
.dist/

# Environment variables - NEVER commit these!
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
*.env
!.env.example
backend/.env
frontend/.env

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
*.tmp
*.temp
.cache/

# Uploads and user-generated content
uploads/
temp/

# Database
*.db
*.sqlite
*.sqlite3

# Secrets and sensitive files
*.pem
*.key
*.cert
*.p12
*.pfx
secrets.js
secrets.json
config/secrets.*

# Miscellaneous
.env.backup
*.orig
package-lock.json.backup

# Hugging Face deployment temp
.hf-deploy/
